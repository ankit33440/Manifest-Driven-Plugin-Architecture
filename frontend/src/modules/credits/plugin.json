{
  "name": "credits",
  "version": "1.0.0",
  "enabled": true,
  "module": "./credits.module",
  "plugin": "./credits.plugin",
  "allowedRoles": ["SUPERADMIN", "PROJECT_DEVELOPER", "VERIFIER", "BUYER"],
  "routes": [],
  "nav": [
    { "label": "Credits", "path": "/credits", "icon": "Leaf", "roles": ["SUPERADMIN", "PROJECT_DEVELOPER", "VERIFIER", "BUYER"] }
