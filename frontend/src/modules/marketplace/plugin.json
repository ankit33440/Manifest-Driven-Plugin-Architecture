      "routes": [],
      "nav": [
        { "label": "Marketplace", "path": "/marketplace", "icon": "ShoppingCart" }
      ],
      "pages": [
        { "path": "/marketplace", "component": "MarketplaceListPage", "title": "Marketplace" },
        { "path": "/marketplace/:id", "component": "MarketplaceDetailPage", "title": "Listing Detail" }
      ],
      "sections": {},
