{
  "name": "credits",
  "version": "1.0.0",
  "enabled": true,
  "module": "./credits.module",
  "plugin": "./credits.plugin",
  "publicRoutes": [],
  "roles": {
    "SUPERADMIN": {
      "routes": [
        { "path": "/credits", "method": "GET" },
        { "path": "/credits/:id", "method": "GET" },
        { "path": "/credits", "method": "POST" },
        { "path": "/credits/:id/retire", "method": "PATCH" },
        { "path": "/credits/:id", "method": "DELETE" }
      ],
      "nav": [
        { "label": "Credits", "path": "/credits", "icon": "BadgeCheck" }
      ],
      "pages": [
        { "path": "/credits", "component": "CreditListPage", "title": "Carbon Credits" },
        { "path": "/credits/:id", "component": "CreditDetailPage", "title": "Credit Detail" }
      ],
      "sections": {
        "CreditDetailPage": [
          { "id": "credit-info", "label": "Credit Information" },
          { "id": "issue-action", "label": "Issue Actions" },
          { "id": "retire-action", "label": "Retire Credit" },
          { "id": "serial-numbers", "label": "Serial Numbers" }
        ]
      },
      "dashboardWidgets": [
        { "component": "CreditStatsWidget", "order": 2 }
      ]
    },
    "CERTIFIER": {
      "routes": [
        { "path": "/credits", "method": "GET" },
        { "path": "/credits/:id", "method": "GET" },
        { "path": "/credits", "method": "POST" },
        { "path": "/credits/:id/retire", "method": "PATCH" }
      ],
      "nav": [
        { "label": "Credits", "path": "/credits", "icon": "BadgeCheck" }
      ],
      "pages": [
        { "path": "/credits", "component": "CreditListPage", "title": "Carbon Credits" },
        { "path": "/credits/:id", "component": "CreditDetailPage", "title": "Credit Detail" }
      ],
      "sections": {
        "CreditDetailPage": [
          { "id": "credit-info", "label": "Credit Information" },
          { "id": "issue-action", "label": "Issue Actions" },
          { "id": "retire-action", "label": "Retire Credit" }
        ]
      },
      "dashboardWidgets": [
        { "component": "CreditStatsWidget", "order": 2 }
      ]
    },
    "PROJECT_DEVELOPER": {
      "routes": [
        { "path": "/credits", "method": "GET" },
        { "path": "/credits/:id", "method": "GET" }
      ],
      "nav": [
        { "label": "Credits", "path": "/credits", "icon": "BadgeCheck" }
      ],
      "pages": [
        { "path": "/credits", "component": "CreditListPage", "title": "Carbon Credits" },
        { "path": "/credits/:id", "component": "CreditDetailPage", "title": "Credit Detail" }
      ],
      "sections": {
        "CreditDetailPage": [
          { "id": "credit-info", "label": "Credit Information" }
        ]
      },
      "dashboardWidgets": [
        { "component": "CreditStatsWidget", "order": 2 }
      ]
    },
    "BUYER": {
      "routes": [
        { "path": "/credits", "method": "GET" },
        { "path": "/credits/:id", "method": "GET" }
      ],
      "nav": [
        { "label": "Credits", "path": "/credits", "icon": "BadgeCheck" }
      ],
      "pages": [
        { "path": "/credits", "component": "CreditListPage", "title": "Carbon Credits" },
        { "path": "/credits/:id", "component": "CreditDetailPage", "title": "Credit Detail" }
      ],
      "sections": {
        "CreditDetailPage": [
          { "id": "credit-info", "label": "Credit Information" }
        ]
      },
      "dashboardWidgets": [
        { "component": "CreditStatsWidget", "order": 2 }
      ]
    }
  },
  "listensTo": ["project.approved"],
  "emits": ["credit.issued", "credit.retired"]
}
