{
  "name": "project",
  "version": "1.0.0",
  "enabled": true,
  "module": "./project.module",
  "plugin": "./project.plugin",
  "publicRoutes": [],
  "roles": {
    "SUPERADMIN": {
      "routes": [
        { "path": "/projects", "method": "GET" },
        { "path": "/projects/:id", "method": "GET" },
        { "path": "/projects/:id/approve", "method": "PATCH" },
        { "path": "/projects/:id/reject", "method": "PATCH" },
        { "path": "/projects/:id", "method": "DELETE" }
      ],
      "nav": [
        { "label": "All Projects", "path": "/projects", "icon": "Layers" }
      ],
      "pages": [
        { "path": "/projects", "component": "ProjectListPage", "title": "Projects" },
        { "path": "/projects/:id", "component": "ProjectDetailPage", "title": "Project Detail" }
      ],
      "sections": {
        "ProjectDetailPage": [
          { "id": "project-info", "label": "Project Information" },
          { "id": "approval-action", "label": "Approval Decision" },
          { "id": "project-timeline", "label": "Timeline" }
        ]
      },
      "dashboardWidgets": [
        { "component": "ProjectStatsWidget", "order": 1 }
      ]
    },
    "PROJECT_DEVELOPER": {
      "routes": [
        { "path": "/projects", "method": "GET" },
        { "path": "/projects/:id", "method": "GET" },
        { "path": "/projects", "method": "POST" },
        { "path": "/projects/:id/submit", "method": "PATCH" },
        { "path": "/projects/draft/:id", "method": "DELETE" }
      ],
      "nav": [
        { "label": "My Projects", "path": "/projects", "icon": "FolderOpen" }
      ],
      "pages": [
        { "path": "/projects", "component": "ProjectListPage", "title": "Projects" },
        { "path": "/projects/new", "component": "ProjectCreatePage", "title": "New Project" },
        { "path": "/projects/:id", "component": "ProjectDetailPage", "title": "Project Detail" }
      ],
      "sections": {
        "ProjectDetailPage": [
          { "id": "project-info", "label": "Project Information" },
          { "id": "submit-action", "label": "Submit for Review" },
          { "id": "project-timeline", "label": "Timeline" }
        ]
      },
      "dashboardWidgets": [
        { "component": "ProjectStatsWidget", "order": 1 }
      ]
    },
    "VERIFIER": {
      "routes": [
        { "path": "/projects", "method": "GET" },
        { "path": "/projects/:id", "method": "GET" }
      ],
      "nav": [
        { "label": "All Projects", "path": "/projects", "icon": "Layers" }
      ],
      "pages": [
        { "path": "/projects", "component": "ProjectListPage", "title": "Projects" },
        { "path": "/projects/:id", "component": "ProjectDetailPage", "title": "Project Detail" }
      ],
      "sections": {
        "ProjectDetailPage": [
          { "id": "project-info", "label": "Project Information" },
          { "id": "project-timeline", "label": "Timeline" }
        ]
      },
      "dashboardWidgets": []
    }
  },
  "listensTo": [],
  "emits": ["project.submitted", "project.approved", "project.rejected"]
}
